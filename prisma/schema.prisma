// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. 사용자 테이블
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  orders    Order[]
}

// 2. 식당 테이블
model Restaurant {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  imageUrl    String
  category    String
  menus       Menu[]
}

// 3. 메뉴 테이블 (식당과 1:N 관계)
model Menu {
  id           Int         @id @default(autoincrement())
  name         String
  price        Int
  description  String
  imageUrl     String
  restaurantId Int
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
}

// 4. 주문 테이블 (사용자와 1:N 관계)
model Order {
  id         Int         @id @default(autoincrement())
  userId     Int
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalPrice Int
  status     String      @default("접수") // 접수 -> 배달중 -> 완료
  createdAt  DateTime    @default(now())
  orderItems OrderItem[]
}

// 5. 주문 상세 테이블 (주문과 메뉴의 N:M 관계를 풀기 위한 중간 테이블)
model OrderItem {
  id       Int  @id @default(autoincrement())
  orderId  Int
  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuId   Int
  menu     Menu  @relation(fields: [menuId], references: [id], onDelete: Cascade)
  quantity Int
  price    Int  // 중요: 주문 당시의 메뉴 가격 (메뉴 가격이 변동되어도 과거 주문 내역 금액을 유지하기 위함)
}
